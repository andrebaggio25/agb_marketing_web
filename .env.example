APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Sao_Paulo

# Só para public/deploy-setup.php (produção após Git). Gerar: openssl rand -hex 16
# DEPLOY_SETUP_TOKEN=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agb_marketing
DB_USERNAME=root
DB_PASSWORD=

# Painel /admin/database (migrations + visão do schema). Em produção pode desativar:
DB_ADMIN_ENABLED=true

MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=AGB Marketing
MAIL_LEAD_TO=contato@suaempresa.com
MAIL_TRANSPORT=mail

# Opcional SMTP:
# MAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_ENCRYPTION=tls
