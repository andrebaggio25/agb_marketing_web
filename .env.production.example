# Copie para .env no servidor de produção e ajuste os valores secretos.
# Nunca commite o arquivo .env real.

APP_ENV=production
APP_DEBUG=false
APP_URL=https://seudominio.com.br
APP_TIMEZONE=America/Sao_Paulo

# Obrigatório para a 1ª visita a /deploy-setup.php?token=... (depois pode remover)
# Gere um segredo: openssl rand -hex 24
DEPLOY_SETUP_TOKEN=

# Em hospedagem compartilhada o host costuma ser 127.0.0.1 ou localhost (confirmar no painel).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nome_da_base_mysql
DB_USERNAME=utilizador_mysql
DB_PASSWORD=sua_senha_mysql

# Recomendado false em produção após aplicar migrations (painel em /admin/database)
DB_ADMIN_ENABLED=false

MAIL_FROM_ADDRESS=noreply@seudominio.com.br
MAIL_FROM_NAME=AGB Marketing
MAIL_LEAD_TO=contato@seudominio.com.br
MAIL_TRANSPORT=smtp

SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=noreply@seudominio.com.br
SMTP_PASS=
SMTP_ENCRYPTION=tls
